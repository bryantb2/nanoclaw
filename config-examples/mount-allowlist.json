{
  "allowedRoots": [
    {
      "path": "~/projects",
      "allowReadWrite": true,
      "description": "Development projects"
    },
    {
      "path": "~/repos",
      "allowReadWrite": true,
      "description": "Per-group persistent repo clones (~/repos/{group}/{repo})"
    },
    {
      "path": "~/nanoclaw/data",
      "allowReadWrite": false,
      "description": "Cross-group output reading (dispatch reads other groups' latest.json)"
    },
    {
      "path": "~/Documents/work",
      "allowReadWrite": false,
      "description": "Work documents (read-only)"
    }
  ],
  "blockedPatterns": [
    "password",
    "secret",
    "token"
  ],
  "nonMainReadOnly": true
}
